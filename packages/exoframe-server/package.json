{
  "name": "exoframe-server",
  "version": "8.0.0-pre",
  "description": "Exoframe server, a self-hosted deployment tool",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": "dist/bin/exoframe-server.js",
  "type": "module",
  "files": [
    "dist/*",
    "tools/install.sh",
    "docker/*",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "start": "node bin/exoframe-server.ts",
    "watch": "node --watch bin/exoframe-server.ts",
    "lint": "eslint src/ test/ bin/ config.ts",
    "test": "NODE_ENV=testing vitest",
    "test:ci": "NODE_ENV=testing vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": "git@github.com:exoframejs/exoframe.git",
  "author": "Tim Ermilov <yamalight@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@fastify/auth": "^5.0.3",
    "@fastify/cors": "^11.1.0",
    "dockerode": "^4.0.9",
    "fastify": "^5.6.2",
    "highland": "^2.13.5",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "lokijs": "^1.5.12",
    "mkdirp": "^3.0.1",
    "node-fetch": "^3.3.2",
    "pino": "^10.1.0",
    "rimraf": "^6.1.0",
    "semver-compare": "^1.0.0",
    "sshpk": "^1.17.0",
    "tar-fs": "^3.0.4"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.8",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "get-port": "^7.1.0",
    "nock": "^14.0.10",
    "nodemon": "^3.1.11",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.0.3",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=26"
  }
}
