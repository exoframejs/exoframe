{
  "name": "exoframe-client",
  "version": "8.0.0",
  "description": "API client for Exoframe server, self-hosted deployment tool",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": "git@github.com:exoframejs/exoframe.git",
  "author": "Tim Ermilov <yamalight@gmail.com>",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "eslint src/ test/ index.ts",
    "test": "TZ=Greenland NODE_ENV=testing vitest",
    "test:ci": "TZ=Greenland NODE_ENV=testing vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "got": "^15.0.7",
    "highland": "^2.13.5",
    "multimatch": "^8.0.0",
    "serialize-error": "^13.0.1",
    "sshpk": "^1.18.0",
    "tar-fs": "^3.1.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "apache-md5": "^1.1.8",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "nock": "^14.0.16",
    "prettier": "^3.9.4",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=26"
  }
}
