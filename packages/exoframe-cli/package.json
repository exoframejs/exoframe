{
  "name": "exoframe",
  "version": "8.0.0-pre",
  "description": "CLI for Exoframe, self-hosted deployment tool",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "type": "module",
  "repository": "git@github.com:exoframejs/exoframe.git",
  "author": "Tim Ermilov <yamalight@gmail.com>",
  "license": "MIT",
  "files": [
    "dist/*"
  ],
  "scripts": {
    "build": "rm -rf dist && ncc build index.ts -o dist",
    "clean": "rm -rf dist",
    "lint": "eslint src/ test/ index.ts",
    "test": "TZ=Greenland NODE_ENV=testing FORCE_COLOR=false vitest",
    "test:ci": "TZ=Greenland NODE_ENV=testing FORCE_COLOR=false vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "apache-md5": "^1.1.8",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "exoframe-client": "^8.0.0-pre",
    "got": "^15.0.7",
    "inquirer": "^14.0.2",
    "lodash": "^4.18.1",
    "open": "^11.0.0",
    "ora": "^9.4.1",
    "pretty-bytes": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@vercel/ncc": "^0.44.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "mock-stdin": "^1.0.0",
    "nock": "^14.0.16",
    "prettier": "^3.9.4",
    "tar-fs": "^3.1.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=26"
  }
}
